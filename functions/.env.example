# Firebase Functions runtime dotenv template.
# Copy this file to functions/.env.read-the-world-74f2a before deploy.
# Do not commit real values.

# Optional scoring gate. Defaults to 50 in code when omitted.
MINIMUM_SCORED_RESPONSES=50

# rtw.codes Universal Links and Android App Links.
APPLE_TEAM_ID=
IOS_BUNDLE_ID=today.readtheworld.app
# Set to false for web/iOS-only deploys before Google Play signing is ready.
ANDROID_APP_LINKS_ENABLED=true
ANDROID_PACKAGE_NAME=today.readtheworld.app
ANDROID_SHA256_CERT_FINGERPRINTS=
