rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        (
          request.auth.token.email == "mike@readtheworld.today" &&
          request.auth.token.email_verified == true &&
          request.auth.token.firebase.sign_in_provider == "google.com"
        )
      );
    }

    function clientProfileKeys() {
      return [
        "displayName",
        "avatarColor",
        "email",
        "phoneNumber",
        "demographics",
        "dailyReminder",
        "onboardedAt",
        "matureContent",
        "createdAt",
        "updatedAt"
      ];
    }

    function clientProfileUpdateKeys() {
      return [
        "displayName",
        "avatarColor",
        "email",
        "phoneNumber",
        "demographics",
        "dailyReminder",
        "onboardedAt",
        "matureContent",
        "updatedAt"
      ];
    }

    function validNotificationTokenCreate() {
      return request.resource.data.keys().hasOnly([
        "token",
        "platform",
        "enabled",
        "createdAt",
        "updatedAt",
        "lastSeenAt"
      ]) &&
        request.resource.data.token is string &&
        request.resource.data.enabled is bool;
    }

    function validNotificationTokenUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "token",
        "platform",
        "enabled",
        "updatedAt",
        "lastSeenAt"
      ]) &&
        request.resource.data.token is string &&
        request.resource.data.enabled is bool;
    }

    function validAnswerDraft(questionId) {
      return request.resource.data.keys().hasOnly([
        "questionId",
        "dailyKey",
        "selectedOptionId",
        "predictedShare",
        "createdAt",
        "updatedAt"
      ]) &&
        request.resource.data.questionId == questionId &&
        request.resource.data.dailyKey is string &&
        request.resource.data.selectedOptionId is string &&
        request.resource.data.predictedShare is int &&
        request.resource.data.predictedShare >= 0 &&
        request.resource.data.predictedShare <= 100;
    }

    match /questions/{questionId} {
      allow read: if isAdmin() || resource.data.status in ["live", "closed"];
      allow create, update, delete: if isAdmin();
    }

    match /dailyResults/{questionId} {
      allow read: if isAdmin() || resource.data.status == "closed";
      allow write: if isAdmin();
    }

    match /questionCounters/{questionId} {
      allow read: if isAdmin() ||
        get(/databases/$(database)/documents/questions/$(questionId)).data.status in ["live", "closed"];
      allow write: if isAdmin();
    }

    match /questionCounters/{questionId}/shards/{shardId} {
      allow read, write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) &&
        request.resource.data.keys().hasOnly(clientProfileKeys());
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(clientProfileUpdateKeys());
      allow delete: if isAdmin();

      match /answers/{questionId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /answerDrafts/{questionId} {
        allow read, delete: if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid) && validAnswerDraft(questionId);
      }

      match /categoryStats/{categoryId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /scoreHistory/{questionId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /friends/{friendUid} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /notificationTokens/{tokenId} {
        allow read, delete: if isOwner(uid) || isAdmin();
        allow create: if isAdmin() || (isOwner(uid) && validNotificationTokenCreate());
        allow update: if isAdmin() || (isOwner(uid) && validNotificationTokenUpdate());
      }

      // v2: mirror of room membership, maintained by callables.
      match /memberships/{roomId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }
    }

    match /leaderboards/{boardId}/{document=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ── v2 Rooms ─────────────────────────────────────────────────────────
    // All room mutations flow through callables (admin SDK bypasses rules),
    // so clients get read-only access scoped by membership. The World room
    // (fixed id "world") is browsable by any signed-in user.
    function isRoomMember(roomId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function isWorldRoom(roomId) {
      return roomId == "world";
    }

    match /rooms/{roomId} {
      // The World's question of the day is public content — the landing
      // page shows it to signed-out visitors.
      allow read: if isAdmin() || isRoomMember(roomId) || isWorldRoom(roomId);
      allow write: if isAdmin();

      match /members/{memberUid} {
        allow read: if isAdmin() || isRoomMember(roomId);
        allow write: if isAdmin();
      }

      match /days/{dailyKey} {
        allow read: if isAdmin() || isRoomMember(roomId) || isWorldRoom(roomId);
        allow write: if isAdmin();

        match /answers/{answerUid} {
          allow read: if isAdmin() || isOwner(answerUid);
          allow write: if isAdmin();
        }
      }

      match /queue/{itemId} {
        allow read: if isAdmin() || isRoomMember(roomId);
        allow write: if isAdmin();
      }
    }

    match /questionBank/{qid} {
      allow read, write: if isAdmin();
    }

    match /flags/{flagId} {
      allow read, write: if isAdmin();
    }

    match /links/{code} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /invites/{code} {
      allow read, write: if isAdmin();
    }

    match /authHandoffs/{code} {
      allow read, write: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /notificationCampaigns/{campaignId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
