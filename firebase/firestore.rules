rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function clientProfileKeys() {
      return [
        "displayName",
        "avatarColor",
        "email",
        "demographics",
        "dailyReminder",
        "createdAt",
        "updatedAt"
      ];
    }

    function clientProfileUpdateKeys() {
      return [
        "displayName",
        "avatarColor",
        "email",
        "demographics",
        "dailyReminder",
        "updatedAt"
      ];
    }

    function validNotificationTokenCreate() {
      return request.resource.data.keys().hasOnly([
        "token",
        "platform",
        "enabled",
        "createdAt",
        "updatedAt",
        "lastSeenAt"
      ]) &&
        request.resource.data.token is string &&
        request.resource.data.enabled is bool;
    }

    function validNotificationTokenUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "token",
        "platform",
        "enabled",
        "updatedAt",
        "lastSeenAt"
      ]) &&
        request.resource.data.token is string &&
        request.resource.data.enabled is bool;
    }

    match /questions/{questionId} {
      allow read: if isAdmin() || resource.data.status in ["live", "closed"];
      allow create, update, delete: if isAdmin();
    }

    match /dailyResults/{questionId} {
      allow read: if isAdmin() || resource.data.status == "closed";
      allow write: if isAdmin();
    }

    match /questionCounters/{questionId} {
      allow read: if isAdmin() ||
        get(/databases/$(database)/documents/questions/$(questionId)).data.status in ["live", "closed"];
      allow write: if isAdmin();
    }

    match /questionCounters/{questionId}/shards/{shardId} {
      allow read, write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) &&
        request.resource.data.keys().hasOnly(clientProfileKeys());
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(clientProfileUpdateKeys());
      allow delete: if isAdmin();

      match /answers/{questionId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /categoryStats/{categoryId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /scoreHistory/{questionId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /friends/{friendUid} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /notificationTokens/{tokenId} {
        allow read, delete: if isOwner(uid) || isAdmin();
        allow create: if isAdmin() || (isOwner(uid) && validNotificationTokenCreate());
        allow update: if isAdmin() || (isOwner(uid) && validNotificationTokenUpdate());
      }
    }

    match /leaderboards/{boardId}/{document=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /links/{code} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /invites/{code} {
      allow read, write: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /notificationCampaigns/{campaignId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
